{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/kr/claude-sonnet-4.5",

  "instructions": "Read memory/INDEX.md and all files in memory/ at session start for full project context. Stack runs via: bash ~/token-saver/bootstrap.sh. TokenSaver proxy: http://localhost:4000. 9Router gateway: http://localhost:20128/v1. ChromaDB: localhost:8000. Never ask about things already described in memory/.",

  "provider": {
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-4o": { "name": "GPT-4o" },
        "o3":     { "name": "o3" }
      }
    },
    "9router": {
      "name": "9Router Local",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "kr/claude-sonnet-4.5":    { "name": "Kiro AI Claude Sonnet 4.5 ($0)" },
        "kr/claude-haiku-4.5":     { "name": "Kiro AI Claude Haiku 4.5 ($0)" },
        "kr/glm-5":                { "name": "Kiro AI GLM-5 ($0)" },
        "kr/deepseek-3.2":         { "name": "Kiro AI DeepSeek 3.2 ($0)" },
        "kr/qwen3-coder-next":     { "name": "Kiro AI Qwen3 Coder Next ($0)" },
        "oc/auto":                 { "name": "OpenCode Free Auto ($0)" },
        "nvidia/openai/gpt-oss-120b":                    { "name": "NVIDIA GPT-OSS 120B (FREE)" },
        "nvidia/nvidia/nemotron-3-super-120b-a12b":      { "name": "NVIDIA Nemotron 120B (FREE)" },
        "nvidia/qwen/qwen3.5-122b-a10b":                 { "name": "NVIDIA Qwen3.5 122B (FREE)" },
        "nvidia/openai/gpt-oss-20b":                     { "name": "NVIDIA GPT-OSS 20B (FREE)" },
        "nvidia/deepseek-ai/deepseek-v4-pro":            { "name": "NVIDIA DeepSeek V4 Pro (FREE)" }
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google AI Studio",
      "options": { "apiKey": "{env:GEMINI_API_KEY}" },
      "models": {
        "gemini-2.5-flash-preview-05-20": { "name": "Gemini 2.5 Flash" },
        "gemini-2.5-pro-preview-06-05":   { "name": "Gemini 2.5 Pro" },
        "gemini-2.0-flash-001":           { "name": "Gemini 2.0 Flash" },
        "gemini-1.5-pro-002":             { "name": "Gemini 1.5 Pro" },
        "gemini-1.5-flash-002":           { "name": "Gemini 1.5 Flash" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter Free Models",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "openrouter/free":                              { "name": "OpenRouter Auto Free" },
        "openai/gpt-oss-120b:free":                    { "name": "GPT-OSS 120B (free)" },
        "google/gemini-2.5-flash:free":                { "name": "Gemini 2.5 Flash (free)" },
        "meta-llama/llama-3.1-8b-instruct:free":       { "name": "Llama 3.1 8B (free)" },
        "qwen/qwen3-coder:free":                       { "name": "Qwen 3 Coder (free)" },
        "qwen/qwen3-next-80b-a3b-instruct:free":       { "name": "Qwen 3 Next 80B (free)" },
        "qwen/qwen3.7-max":                            { "name": "Qwen 3.7 Max" },
        "qwen/qwen3.6-plus":                           { "name": "Qwen 3.6 Plus" },
        "qwen/qwen3.6-flash":                          { "name": "Qwen 3.6 Flash" },
        "qwen/qwen3-max":                              { "name": "Qwen 3 Max" },
        "qwen/qwen3-max-thinking":                     { "name": "Qwen 3 Max (Thinking)" },
        "qwen/qwen3-coder":                            { "name": "Qwen 3 Coder" },
        "qwen/qwen-2.5-coder-32b-instruct":            { "name": "Qwen 2.5 Coder 32B" },
        "qwen/qwen-2.5-72b-instruct":                  { "name": "Qwen 2.5 72B" },
        "deepseek/deepseek-r1-distill-qwen-32b":       { "name": "DeepSeek R1 Distill Qwen 32B" }
      }
    },
    "opencode-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen (Free models)",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1",
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash-free":          { "name": "DeepSeek V4 Flash (free)" },
        "kimi-k2-free":                    { "name": "Kimi K2 (free)" },
        "deepseek-v3.2-free":              { "name": "DeepSeek V3.2 (free)" },
        "qwen3.5-coder-free":              { "name": "Qwen 3.5 Coder (free)" },
        "deepseek-r1-distill-qwen-32b":    { "name": "DeepSeek R1 Distill Qwen 32B" },
        "kimi-k2.5":                       { "name": "Kimi K2.5" },
        "kimi-k2.6":                       { "name": "Kimi K2.6" },
        "qwq-32b":                         { "name": "QWQ 32B" }
      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "meta/llama-3.3-70b-instruct":    { "name": "Llama 3.3 70B (NIM free)" },
        "deepseek-ai/deepseek-v3.1":      { "name": "DeepSeek V3.1 (NIM free)" }
      }
    },
    "antigravity-manager": {
      "npm": "@ai-sdk/anthropic",
      "name": "Antigravity Manager",
      "options": {
        "baseURL": "http://127.0.0.1:8045/v1",
        "apiKey": "{env:ANTIGRAVITY_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text","image","pdf"], "output": ["text"] }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text","image","pdf"], "output": ["text"] },
          "reasoning": true
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local (M1 8GB)",
      "options": { "baseURL": "http://localhost:11434/v1", "apiKey": "ollama" },
      "models": {
        "qwen3:4b":          { "name": "Qwen3 4B (local, 21 t/s)",          "limit": { "context": 2048, "output": 1024 } },
        "qwen2.5-coder:3b": { "name": "Qwen2.5 Coder 3B (local, 28 t/s)",  "limit": { "context": 2048, "output": 1024 } },
        "llama3.2:3b":      { "name": "Llama 3.2 3B (local, 28 t/s)",       "limit": { "context": 2048, "output": 1024 } }
      }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX Native (M1, fallback)",
      "options": { "baseURL": "http://localhost:8082/v1", "apiKey": "mlx" },
      "models": {
        "qwen3-4b": { "name": "Qwen3 4B MLX (20 t/s)", "limit": { "context": 2048, "output": 1024 } }
      }
    }
  },

  "enabled_providers": [
    "ollama", "mlx", "opencode-go", "opencode-zen",
    "9router", "google", "openrouter", "nvidia", "antigravity-manager"
  ],

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "${PWD}"]
    },
    "semantic-compressor": {
      "type": "local",
      "command": ["node", "packages/semantic-compressor/dist/index.js"]
    },
    "context-degradation": {
      "type": "local",
      "command": ["node", "packages/context-degradation-mcp/dist/index.js"]
    },
    "memory-mcp": {
      "type": "local",
      "command": ["node", "packages/memory-mcp/dist/index.js"],
      "environment": {
        "OBSIDIAN_VAULT_PATH": "/Users/work/Obsidian-Library",
        "CHROMA_HOST": "localhost",
        "CHROMA_PORT": "8000"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["playwright-mcp"]
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@fre4x/github"]
    },
    "composio": {
      "type": "local",
      "command": ["npx", "-y", "@composio/mcp@latest", "start"]
    },
    "appflowy": {
      "type": "local",
      "command": ["doppler", "run", "--project", "serpent", "--config", "dev_personal", "--", "uvx", "appflowy-mcp"]
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "@figma/mcp-server"]
    },
    "reaktmy": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://reaktmy.vercel.app/mcp"]
    }
  }
}
